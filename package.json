{
  "name": "@ocavue/eslint-config",
  "type": "module",
  "version": "4.5.4",
  "packageManager": "pnpm@10.33.0",
  "description": "Opinionated ESLint config preset",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/eslint-config.git"
  },
  "bugs": "https://github.com/ocavue/eslint-config/issues",
  "keywords": [
    "eslint",
    "eslint-config",
    "typescript",
    "markdown",
    "react",
    "vue"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest",
    "build": "tsc -b",
    "fix": "pnpm run fix:eslint && pnpm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier --write .",
    "lint": "pnpm run lint:ts && pnpm run lint:eslint && pnpm run lint:knip && pnpm run lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint:ts": "tsc -b .",
    "lint:knip": "knip",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/markdown": "^8.0.1",
    "@unocss/eslint-config": "^66.6.8",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-antfu": "^3.2.2",
    "eslint-plugin-command": "^3.5.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-react-hooks": "^7.1.0 || 7.1.0-canary-404b38c7-20260408 || 7.1.0-canary-705268dc-20260409 || 7.1.0-canary-00f063c3-20260415",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.58.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^20.19.27",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "knip": "^6.3.1",
    "pkg-pr-new": "^0.0.66",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
