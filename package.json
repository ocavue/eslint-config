{
  "name": "@ocavue/eslint-config",
  "type": "module",
  "version": "4.10.0",
  "packageManager": "pnpm@11.9.0",
  "description": "Opinionated ESLint config preset",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/eslint-config.git"
  },
  "bugs": "https://github.com/ocavue/eslint-config/issues",
  "keywords": [
    "eslint",
    "eslint-config",
    "typescript",
    "markdown",
    "react",
    "vue"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest",
    "build": "tsc -b",
    "fix": "pnpm run fix:eslint && pnpm run fix:oxfmt",
    "fix:eslint": "eslint --fix .",
    "fix:oxfmt": "oxfmt",
    "lint": "pnpm run lint:ts && pnpm run lint:eslint && pnpm run lint:knip && pnpm run lint:oxfmt",
    "lint:eslint": "eslint .",
    "lint:oxfmt": "oxfmt --check",
    "lint:ts": "tsc -b .",
    "lint:knip": "knip",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/markdown": "^8.0.2",
    "@unocss/eslint-config": "^66.7.3",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-antfu": "^3.2.3",
    "eslint-plugin-command": "^3.5.2",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "devDependencies": {
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "jiti": "^2.7.0",
    "knip": "^6.23.0",
    "oxfmt": "^0.56.0",
    "pkg-pr-new": "^0.0.75",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
